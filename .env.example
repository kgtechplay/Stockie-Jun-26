# =========================
# Kite Connect (Zerodha)
# =========================
# API key and secret from your Kite Connect developer app
KITE_API_KEY=your_kite_api_key
KITE_API_SECRET=your_kite_api_secret

# Optional local cache path. Cron jobs should read the access token from
# the database table KiteAccessToken, not from a KITE_ACCESS_TOKEN env var.
KITE_ACCESS_TOKEN_PATH=/path/to/kite_access_token.txt

# Optional: fully automate daily_get_kite_access_token.py with Playwright.
# Install once with: pip install -r requirements.txt && python -m playwright install chromium
KITE_AUTO_LOGIN=1
KITE_LOGIN_HEADLESS=1
KITE_2FA_MODE=totp
KITE_USER_ID=your_kite_user_id
KITE_PASSWORD=your_kite_password
KITE_TOTP_SECRET=your_totp_secret_from_authenticator_setup
# KITE_TOTP_CODE=123456
# KITE_PIN=123456
KITE_REDIRECT_HOST=127.0.0.1
KITE_REDIRECT_PORT=5000
KITE_TOKEN_WAIT_SECONDS=180

# =========================
# Azure SQL Database
# =========================
# Full ODBC connection string for the Options database
AZURE_SQL_CONN_STR=Driver={ODBC Driver 18 for SQL Server};Server=tcp:<server>.database.windows.net,1433;Database=<database>;Uid=<username>;Pwd=<password>;Encrypt=yes;TrustServerCertificate=no;Connection Timeout=60;

# =========================
# Supabase Postgres
# =========================
# Set DATABASE_PROVIDER=supabase to make daily scripts use Supabase/Postgres.
DATABASE_PROVIDER=supabase
SUPABASE_CONN_STR=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require

# =========================
# Azure AI Agents / Azure OpenAI
# =========================
# These are used by src/agents/*/agent.py through src/agents/azure_agent_client.py.
# AZURE_AI_* aliases are also supported.
AZURE_OPENAI_ENDPOINT=https://<resource-name>.openai.azure.com
AZURE_OPENAI_API_KEY=your_azure_openai_api_key
AZURE_OPENAI_DEPLOYMENT=your_model_deployment_name
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# =========================
# Pipeline config
# =========================
# Comma-separated NSE underlyings to track for index strategies
TARGET_UNDERLYINGS=NIFTY,BANKNIFTY

# =========================
# Optional
# =========================
# Set to 1 to use the agentic LLM aggregator in predictions (slower, requires Anthropic API key)
# USE_AGENTIC_AGGREGATOR=0
